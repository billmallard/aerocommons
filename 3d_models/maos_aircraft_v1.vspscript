// MAOS Aircraft — VSPAERO Analysis v1.3
// Fix: use GetStringResults(rid,"ResultsVec") for multi-alpha sweep + correct key names
// Wing + H-tail + V-tail only in the VLM thin-surface set.
// Pod and boom added to model for STL export / visual, excluded from VLM.
// Units: feet

void main()
{
    Print( "=== MAOS VSPAERO Analysis v1.1 ===" );

    string vsp_file = "/workspace/analysis/maos_aircraft_v1.vsp3";

    // ── Design parameters ─────────────────────────────────────────────────────
    double POD_L  = 13.0;    double POD_W  = 4.3333;  double POD_H  = 4.8333;
    double BOOM_X = 10.0;    double BOOM_Z = 2.0;     double BOOM_L = 15.0;
    double BOOM_D = 1.0;
    double WING_X = 5.975;   double WING_Z = 2.417;
    double WING_HS = 15.0;   double WING_RC = 5.1;    double WING_TC = 3.0;
    double HT_X   = 23.5;    double HT_Z   = 2.0;
    double HT_HS  = 5.0;     double HT_RC  = 2.2;     double HT_TC  = 1.4;
    double VT_X   = 23.0;    double VT_Z   = 2.0;
    double VT_HS  = 4.5;     double VT_RC  = 2.5;     double VT_TC  = 1.5;

    // ── Pod fuselage ──────────────────────────────────────────────────────────
    string pod = AddGeom( "FUSELAGE", "" );
    SetGeomName( pod, "Pod" );
    SetParmVal( pod, "Length", "Design", POD_L );
    string pxss = GetXSecSurf( pod, 0 );

    // Default fuselage has 5 sections (XSec_0–4).
    // Insert 3 more into the aft body to curve the taper upward toward the boom.
    // After inserts: XSec_0–7 (nose tip, shoulder, cabin, + 4 aft taper steps, tail tip).
    InsertXSec( pod, 3, XS_ELLIPSE );
    InsertXSec( pod, 4, XS_ELLIPSE );
    InsertXSec( pod, 5, XS_ELLIPSE );

    // XSec_0: nose tip (XS_POINT). Slight downward shift per user's adjustment.
    SetParmVal( pod, "XLocPercent", "XSec_0", 0.000 );
    SetParmVal( pod, "ZLocPercent", "XSec_0", -0.053 );

    // XSec_1: windscreen shoulder — full section break at 29% (Citation-style rapid widening)
    SetParmVal( pod, "XLocPercent",    "XSec_1",      0.293 );
    SetParmVal( pod, "Ellipse_Width",  "XSecCurve_1", POD_W );
    SetParmVal( pod, "Ellipse_Height", "XSecCurve_1", POD_H );
    SetParmVal( pod, "ZLocPercent",    "XSec_1",      0.0   );

    // XSec_2: max cabin cross-section
    SetParmVal( pod, "XLocPercent",    "XSec_2",      0.500 );
    SetParmVal( pod, "Ellipse_Width",  "XSecCurve_2", POD_W );
    SetParmVal( pod, "Ellipse_Height", "XSecCurve_2", POD_H );
    SetParmVal( pod, "ZLocPercent",    "XSec_2",      0.0   );

    // XSec_3–6: aft taper — symmetric, all centered at Z=0.
    // Shifting ZLocPercent (spine-bending) creates visible kinks; avoid it here.
    // The asymmetric "flat top, curved bottom" look requires GENERAL_FUSE sections
    // set interactively in the OpenVSP GUI — not achievable via symmetric ellipse script.

    // XSec_3: 64% — start aft taper
    SetParmVal( pod, "XLocPercent",    "XSec_3",      0.64  );
    SetParmVal( pod, "Ellipse_Width",  "XSecCurve_3", 3.8   );
    SetParmVal( pod, "Ellipse_Height", "XSecCurve_3", 4.3   );
    SetParmVal( pod, "ZLocPercent",    "XSec_3",      0.0   );

    // XSec_4: 74%
    SetParmVal( pod, "XLocPercent",    "XSec_4",      0.74  );
    SetParmVal( pod, "Ellipse_Width",  "XSecCurve_4", 2.8   );
    SetParmVal( pod, "Ellipse_Height", "XSecCurve_4", 3.2   );
    SetParmVal( pod, "ZLocPercent",    "XSec_4",      0.0   );

    // XSec_5: 83%
    SetParmVal( pod, "XLocPercent",    "XSec_5",      0.83  );
    SetParmVal( pod, "Ellipse_Width",  "XSecCurve_5", 1.8   );
    SetParmVal( pod, "Ellipse_Height", "XSecCurve_5", 2.2   );
    SetParmVal( pod, "ZLocPercent",    "XSec_5",      0.0   );

    // XSec_6: 92% — near boom diameter
    SetParmVal( pod, "XLocPercent",    "XSec_6",      0.92  );
    SetParmVal( pod, "Ellipse_Width",  "XSecCurve_6", 1.0   );
    SetParmVal( pod, "Ellipse_Height", "XSecCurve_6", 1.2   );
    SetParmVal( pod, "ZLocPercent",    "XSec_6",      0.0   );

    // XSec_7: tail tip (XS_POINT)
    SetParmVal( pod, "XLocPercent",    "XSec_7",      1.000 );
    SetParmVal( pod, "ZLocPercent",    "XSec_7",      0.0   );

    SetXSecTanAngles( GetXSec( pxss, 0 ), XSEC_BOTH_SIDES,  70 );
    SetXSecTanAngles( GetXSec( pxss, 7 ), XSEC_BOTH_SIDES, -90 );

    // ── Tail boom ─────────────────────────────────────────────────────────────
    string boom = AddGeom( "FUSELAGE", "" );
    SetGeomName( boom, "Tail_Boom" );
    SetParmVal( boom, "Length",         "Design", BOOM_L );
    SetParmVal( boom, "X_Rel_Location", "XForm",  BOOM_X );
    SetParmVal( boom, "Z_Rel_Location", "XForm",  BOOM_Z );
    string bxss = GetXSecSurf( boom, 0 );
    SetParmVal( boom, "XLocPercent",    "XSec_1",      0.08   );
    SetParmVal( boom, "Ellipse_Width",  "XSecCurve_1", BOOM_D );
    SetParmVal( boom, "Ellipse_Height", "XSecCurve_1", BOOM_D );
    SetParmVal( boom, "XLocPercent",    "XSec_2",      0.50   );
    SetParmVal( boom, "Ellipse_Width",  "XSecCurve_2", BOOM_D );
    SetParmVal( boom, "Ellipse_Height", "XSecCurve_2", BOOM_D );
    SetParmVal( boom, "XLocPercent",    "XSec_3",      0.92   );
    SetParmVal( boom, "Ellipse_Width",  "XSecCurve_3", BOOM_D );
    SetParmVal( boom, "Ellipse_Height", "XSecCurve_3", BOOM_D );
    SetXSecTanAngles( GetXSec( bxss, 0 ), XSEC_BOTH_SIDES,  90 );
    SetXSecTanAngles( GetXSec( bxss, 4 ), XSEC_BOTH_SIDES, -90 );

    // ── Wing ──────────────────────────────────────────────────────────────────
    string wing = AddGeom( "WING", "" );
    SetGeomName( wing, "Wing" );
    SetParmVal( wing, "X_Rel_Location", "XForm", WING_X );
    SetParmVal( wing, "Z_Rel_Location", "XForm", WING_Z );
    SetDriverGroup( wing, 1, SPAN_WSECT_DRIVER, ROOTC_WSECT_DRIVER, TIPC_WSECT_DRIVER );
    SetParmVal( wing, "Span",       "XSec_1", WING_HS );
    SetParmVal( wing, "Root_Chord", "XSec_1", WING_RC );
    SetParmVal( wing, "Tip_Chord",  "XSec_1", WING_TC );
    SetParmVal( wing, "Sweep",      "XSec_1", 2.0     );
    SetParmVal( wing, "Dihedral",   "XSec_1", 2.0     );

    // ── Horizontal tail ───────────────────────────────────────────────────────
    string htail = AddGeom( "WING", "" );
    SetGeomName( htail, "H_Tail" );
    SetParmVal( htail, "X_Rel_Location", "XForm", HT_X );
    SetParmVal( htail, "Z_Rel_Location", "XForm", HT_Z );
    SetDriverGroup( htail, 1, SPAN_WSECT_DRIVER, ROOTC_WSECT_DRIVER, TIPC_WSECT_DRIVER );
    SetParmVal( htail, "Span",       "XSec_1", HT_HS );
    SetParmVal( htail, "Root_Chord", "XSec_1", HT_RC );
    SetParmVal( htail, "Tip_Chord",  "XSec_1", HT_TC );
    SetParmVal( htail, "Sweep",      "XSec_1", 10.0  );

    // ── Vertical tail ─────────────────────────────────────────────────────────
    string vtail = AddGeom( "WING", "" );
    SetGeomName( vtail, "V_Tail" );
    SetParmVal( vtail, "X_Rel_Location", "XForm", VT_X  );
    SetParmVal( vtail, "Z_Rel_Location", "XForm", VT_Z  );
    SetParmVal( vtail, "X_Rel_Rotation", "XForm", 90.0  );
    SetParmVal( vtail, "Sym_Planar_Flag","Sym",    0     );
    SetDriverGroup( vtail, 1, SPAN_WSECT_DRIVER, ROOTC_WSECT_DRIVER, TIPC_WSECT_DRIVER );
    SetParmVal( vtail, "Span",       "XSec_1", VT_HS );
    SetParmVal( vtail, "Root_Chord", "XSec_1", VT_RC );
    SetParmVal( vtail, "Tip_Chord",  "XSec_1", VT_TC );
    SetParmVal( vtail, "Sweep",      "XSec_1", 25.0  );

    Update();

    // ── Assign geometry to sets ───────────────────────────────────────────────
    // SET_ALL = 0, default sets 0-2 are reserved.
    // Use set 3 for "lifting surfaces only" (for VLM)
    // Use set 4 for "bodies only" (for CompGeom wetted area)
    int LIFT_SET = 3;   // VLM thin surfaces
    int BODY_SET = 4;   // Bodies for drag estimation

    SetSetFlag( wing,  LIFT_SET, true );
    SetSetFlag( htail, LIFT_SET, true );
    SetSetFlag( vtail, LIFT_SET, true );
    SetSetFlag( pod,   BODY_SET, true );
    SetSetFlag( boom,  BODY_SET, true );

    // ── Save and reload ───────────────────────────────────────────────────────
    WriteVSPFile( vsp_file, SET_ALL );
    Print( "Saved: " + vsp_file );
    ExportFile( "/workspace/analysis/maos_aircraft_v1.stl", SET_ALL, EXPORT_STL );
    ClearVSPModel();
    ReadVSPFile( vsp_file );

    // ── CompGeom — wetted area for drag estimate ──────────────────────────────
    Print( "Running CompGeom for wetted areas..." );
    string cg_id  = ComputeCompGeom( SET_ALL, false, 0 );
    string cg_res = FindLatestResultsID( "Comp_Geom" );
    array<double> wet_area = GetDoubleResults( cg_res, "Wet_Area" );
    array<double> ref_area = GetDoubleResults( cg_res, "Theo_Area" );
    Print( "Total wetted area: " + wet_area[0] + " ft²" );
    Print( "Total ref area:    " + ref_area[0] + " ft²" );

    // ── VSPAERO: VLM on lifting surfaces only ─────────────────────────────────
    string cg_vlm = "VSPAEROComputeGeometry";
    SetAnalysisInputDefaults( cg_vlm );

    array<int> thick_s = GetIntAnalysisInput( cg_vlm, "GeomSet" );
    array<int> thin_s  = GetIntAnalysisInput( cg_vlm, "ThinGeomSet" );
    thick_s[0] = SET_NONE;
    thin_s[0]  = LIFT_SET;   // ONLY wing + h-tail + v-tail
    SetIntAnalysisInput( cg_vlm, "GeomSet",     thick_s );
    SetIntAnalysisInput( cg_vlm, "ThinGeomSet", thin_s  );

    Print( "Running VSPAEROComputeGeometry on lifting surfaces..." );
    ExecAnalysis( cg_vlm );
    Print( "ComputeGeom complete." );

    // ── VSPAERO: alpha sweep ──────────────────────────────────────────────────
    string sw = "VSPAEROSweep";
    SetAnalysisInputDefaults( sw );

    array<int> gs; gs.push_back( LIFT_SET );
    SetIntAnalysisInput( sw, "GeomSet", gs, 0 );

    array<int> rf; rf.push_back(1);
    SetIntAnalysisInput( sw, "RefFlag", rf, 0 );

    array<double> sref; sref.push_back(121.5);  // actual wing area from geometry
    SetDoubleAnalysisInput( sw, "Sref", sref, 0 );
    array<double> bref; bref.push_back(30.0);
    SetDoubleAnalysisInput( sw, "bref", bref, 0 );
    array<double> cref_; cref_.push_back(4.05);
    SetDoubleAnalysisInput( sw, "cref", cref_, 0 );

    array<string> wid = FindGeomsWithName( "Wing" );
    SetStringAnalysisInput( sw, "WingID", wid, 0 );

    array<double> as; as.push_back(-2.0); SetDoubleAnalysisInput(sw,"AlphaStart",as,0);
    array<double> ae; ae.push_back(12.0); SetDoubleAnalysisInput(sw,"AlphaEnd",  ae,0);
    array<int>    an; an.push_back(8);    SetIntAnalysisInput(sw,   "AlphaNpts", an,0);
    array<double> ma; ma.push_back(0.234); SetDoubleAnalysisInput(sw,"MachStart",ma,0);
    array<int>    mn; mn.push_back(1);     SetIntAnalysisInput(sw,   "MachNpts", mn,0);

    Print( "Running alpha sweep -2 to +12 deg, Mach 0.234..." );
    string rid = ExecAnalysis( sw );
    Print( "Sweep complete." );

    // ── Extract results ───────────────────────────────────────────────────────
    // Sweep returns one VSPAERO_History result per alpha; collect via ResultsVec.
    // Each history result stores one value per wake-iteration convergence step.
    // Take the LAST element of each array (final converged wake iteration).
    array<string> res_vec = GetStringResults( rid, "ResultsVec", 0 );

    // Body drag estimate (analytical — not from VLM)
    // Skin friction + form factor method
    // Wetted area from CompGeom above; Cf ~ 0.003 for turbulent, FF ~ 1.3 body form
    // CD_body = Cf * FF * Swet / Sref
    double Cf_pod  = 0.0030;   double FF_pod  = 1.4;   double Swet_pod  = 180.0; // est ft²
    double Cf_boom = 0.0027;   double FF_boom = 1.15;  double Swet_boom = 47.0;  // est ft²
    double Sref = 121.5;
    double CD_pod  = Cf_pod  * FF_pod  * Swet_pod  / Sref;  // ~0.0063
    double CD_boom = Cf_boom * FF_boom * Swet_boom  / Sref;  // ~0.0011
    double CD_gear = 0.0050;  // fixed faired tricycle gear
    double CD0_est = CD_pod + CD_boom + CD_gear;

    // Print drag polar
    Print( "" );
    Print( "=== DRAG POLAR: MAOS Wing + Tails (VLM)  Sref=121.5 ft²  Mach=0.234 ===" );
    Print( "" );
    Print( "Body drag estimates (Swet method, not from VLM):" );
    Print( "  Pod:  Cf=0.0030, FF=1.40, Swet~180 ft²  -> CD_pod  = " + CD_pod  );
    Print( "  Boom: Cf=0.0027, FF=1.15, Swet~ 47 ft²  -> CD_boom = " + CD_boom );
    Print( "  Gear (fixed faired):                     -> CD_gear = " + CD_gear );
    Print( "  CD0_bodies = " + CD0_est );
    Print( "" );
    Print( "alpha    CL       CDi(VLM)  CDtot(VLM)  CD_total   L/D      CMy" );
    Print( "-----------------------------------------------------------------------" );
    for ( int i = 0; i < int(res_vec.size()); i++ )
    {
        string h = res_vec[i];
        array<double> aoa_v   = GetDoubleResults( h, "FC_AoA_", 0 );
        array<double> CL_v    = GetDoubleResults( h, "CLtot",   0 );
        array<double> CDi_v   = GetDoubleResults( h, "CDi",     0 );
        array<double> CDtot_v = GetDoubleResults( h, "CDtot",   0 );
        array<double> CMy_v   = GetDoubleResults( h, "CMytot",  0 );
        // Final wake iteration = last element
        int last = int(CL_v.size()) - 1;
        double aoa  = aoa_v[0];
        double CL   = CL_v[last];
        double CDi  = CDi_v[last];
        double CDtot = CDtot_v[last];
        double CMy  = CMy_v[last];
        double CD_total = CDtot + CD0_est;
        double ld = ( CD_total > 0.0005 ) ? CL / CD_total : 0.0;
        Print( aoa + "   " + CL + "   " + CDi + "   " + CDtot
               + "   " + CD_total + "   " + ld + "   " + CMy );
    }

    // Cruise check
    Print( "" );
    Print( "=== CRUISE CONDITION CHECK ===" );
    Print( "W=2600 lb  V=155 KTAS SL  S=121.5 ft²  AR=" + ( 30.0*30.0/121.5 ) );
    Print( "q_SL = 81.3 psf   CL_cruise = 2600/(81.3x121.5) = " + ( 2600.0/(81.3*121.5) ) );
    double CL_cr = 2600.0 / (81.3 * 121.5);
    double CDi_cr = CL_cr * CL_cr / ( 3.14159 * (900.0/121.5) * 0.80 );
    double CD_cr = CD0_est + CDi_cr;
    Print( "CDi_cruise (e=0.80) = " + CDi_cr );
    Print( "CD_total   = " + CD_cr );
    Print( "L/D cruise = " + CL_cr/CD_cr );
    Print( "" );
    Print( "Design target L/D=14 requires CD_total=" + CL_cr/14.0 );
    Print( "That requires CD0=" + ( CL_cr/14.0 - CDi_cr ) );
    Print( "Our CD0_bodies estimate = " + CD0_est );
    Print( "" );
    double gap = CD0_est - ( CL_cr/14.0 - CDi_cr );
    Print( "Gap to close = " + gap + " (positive = we exceed the L/D=14 CD budget)" );
    Print( "" );
    Print( "=== COMPLETE ===" );
}
